{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "TodoWrite",
      "NotebookEdit",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git config*)",
      "Bash(git init)",
      "Bash(git rev-parse*)",
      "Bash(git remote -v)",
      "Bash(git remote show*)",
      "Bash(ls*)",
      "Bash(pwd)",
      "Bash(mkdir *)",
      "PowerShell(git status*)",
      "PowerShell(git diff*)",
      "PowerShell(git log*)",
      "PowerShell(git add *)",
      "PowerShell(git commit*)",
      "PowerShell(git branch*)",
      "PowerShell(git config*)",
      "PowerShell(git rev-parse*)",
      "PowerShell(Get-ChildItem*)",
      "PowerShell(New-Item *)",
      "PowerShell(Test-Path *)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rm -*)",
      "Bash(rmdir *)",
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git checkout --*)",
      "Bash(git clean*)",
      "Bash(git branch -D*)",
      "Bash(git branch -d*)",
      "Bash(npm install*)",
      "Bash(npm i *)",
      "Bash(npm uninstall*)",
      "Bash(yarn add*)",
      "Bash(pip install*)",
      "PowerShell(Remove-Item *)",
      "PowerShell(rm *)",
      "PowerShell(del *)",
      "PowerShell(rmdir *)",
      "PowerShell(git push*)",
      "PowerShell(git reset --hard*)",
      "PowerShell(npm install*)"
    ]
  }
}
